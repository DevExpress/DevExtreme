{
    "extends": [
        "config:js-lib",
        "github>DevExpress/devextreme-renovate-config"
    ],
    "prConcurrentLimit": 2,
    "semanticCommits": "enabled",
    "labels": [
        "dependencies"
    ],
    "vulnerabilityAlerts": {
        "enabled": true,
        "automerge": true
    },
    "rebaseWhen": "conflicted",
    "packageRules": [
        {
            "matchPackageNames": [
                "openai",
                "rehype-minify-whitespace",
                "rehype-parse",
                "rehype-remark",
                "rehype-stringify",
                "remark-parse",
                "remark-rehype",
                "remark-stringify",
                "unified"
            ],
            "enabled": false
        },
        {
            "groupName": "CLDR",
            "matchPackageNames": [
                "cldr-{/,}**"
            ]
        },
        {
            "groupName": "actions",
            "matchUpdateTypes": [
                "major"
            ],
            "automerge": true,
            "matchPackageNames": [
                "actions/{/,}**"
            ]
        },
        {
            "matchPackageNames": [
                "chrome",
                "firefox"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "automerge": true
        },
        {
            "matchPackageNames": [
                "chrome",
                "firefox"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "enabled": false
        },
        {
            "enabled": false,
            "matchPackageNames": [
                "/^@devextreme-generator//"
            ]
        },
        {
            "matchPackageNames": [
                "devexpress-gantt",
                "devexpress-diagram",
                "rrule",
                "sass-embedded",
                "systemjs"
            ],
            "enabled": false
        },
        {
            "matchPackageNames": [
                "typescript",
                "typescript-min"
            ],
            "matchUpdateTypes": [
                "major",
                "minor"
            ],
            "enabled": false
        },
        {
            "matchUpdateTypes": [
                "major"
            ],
            "dependencyDashboardApproval": true,
            "matchPackageNames": [
                "*",
                "!cldr-{/,}**",
                "!chrome{/,}**",
                "!firefox{/,}**"
            ]
        },
        {
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true,
            "matchDatasources": [
                "npm"
            ],
            "minimumReleaseAge": "7 days",
            "matchPackageNames": [
                "*"
            ]
        },
        {
            "matchPackageNames": [
                "gulp-sass",
                "gulp-babel",
                "gulp-typescript",
                "gulp-clean",
                "gulp-minify",
                "gulp-replace",
                "gulp-sourcemaps",
                "gulp-cache",
                "gulp-plumber",
                "gulp-shell",
                "gulp-cached",
                "gulp-concat",
                "gulp-each",
                "gulp-eol",
                "gulp-file",
                "gulp-flatmap",
                "gulp-footer",
                "gulp-header",
                "gulp-if",
                "gulp-jsbeautifier",
                "gulp-multi-process",
                "gulp-notify",
                "gulp-rename",
                "gulp-tap",
                "gulp-uglify-es",
                "gulp-watch"
            ],
            "enabled": false
        }
    ],
    "lockFileMaintenance": {
        "enabled": true,
        "schedule": [
            "before 4am on Thursday"
        ]
    },
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^\\.github\\/.+\\.ya?ml$/"
            ],
            "matchStrings": [
                "node-version:\\s*['\"]?(?<currentValue>\\d+([\\.-]\\d+)*)['\"]?(\\s|$)"
            ],
            "depNameTemplate": "node",
            "versioningTemplate": "node",
            "datasourceTemplate": "node-version"
        },
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^\\.github\\/.+\\.ya?ml$/"
            ],
            "matchStrings": [
                "chrome-version:\\s*['\"]?(?<currentValue>\\d+(\\.\\d+)+)(-1)?['\"]?(\\s|$)"
            ],
            "depNameTemplate": "chrome",
            "versioningTemplate": "regex:(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)\\.(?<build>\\d+)",
            "datasourceTemplate": "custom.chrome"
        },
        {
            "customType": "regex",
            "managerFilePatterns": [
                "/^\\.github\\/.+\\.ya?ml$/"
            ],
            "matchStrings": [
                "firefox-version:\\s*['\"]?(?<currentValue>\\d+(\\.\\d+)+)['\"]?(\\s|$)"
            ],
            "depNameTemplate": "firefox",
            "versioningTemplate": "semver",
            "datasourceTemplate": "custom.firefox"
        }
    ],
    "customDatasources": {
        "chrome": {
            "defaultRegistryUrlTemplate": "https://versionhistory.googleapis.com/v1/chrome/platforms/linux/channels/stable/versions",
            "transformTemplates": [
                "{ \"releases\": $.versions }"
            ]
        },
        "firefox": {
            "defaultRegistryUrlTemplate": "https://product-details.mozilla.org/1.0/firefox_history_stability_releases.json",
            "transformTemplates": [
                "{ \"releases\": $each($, function($v, $k) { { \"version\": $k } }) }"
            ]
        }
    }
}
