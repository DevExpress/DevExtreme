{
  "name": "devextreme-testcafe-tests",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "e2e/testcafe-devextreme",
  "projectType": "application",
  "targets": {
    "lint": {
      "executor": "nx:run-script",
      "options": {
        "script": "lint"
      },
      "cache": true
    },
    "test": {
      "executor": "nx:run-script",
      "options": {
        "script": "test"
      },
      "dependsOn": [
        "test--accessibility-common-1",
        "test--accessibility-common-2",
        "test--accessibility-common-3",
        "test--accessibility-common-4",
        "test--accessibility-common-5",
        "test--accessibility-common-6",
        "test--accessibility-common-7"
      ],
      "cache": true
    },
    "test--accessibility-common-1": {
      "dependsOn": ["^build"],
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm run test",
        "args": "--browsers=chrome:devextreme-shr2 --componentFolder accessibility/common --indices 1/7 --concurrency=1"
      }
    },
    "test--accessibility-common-2": {
      "dependsOn": ["^build"],
