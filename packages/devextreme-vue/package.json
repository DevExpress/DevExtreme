{
  "name": "devextreme-vue",
  "version": "25.2.8",
  "description": "DevExtreme UI and Visualization Components for Vue",
  "repository": {
    "type": "git",
    "url": "https://github.com/DevExpress/DevExtreme.git",
    "directory": "packages/devextreme-vue"
  },
  "sideEffects": false,
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./cjs/index.d.ts",
  "scripts": {
    "clean": "pnpm --workspace-root nx run devextreme-vue:clean",
    "regenerate": "pnpm --workspace-root nx run devextreme-vue:regenerate",
    "lint": "eslint --ignore-pattern src/core/__tests__/ src/core",
    "build": "pnpm --workspace-root nx run devextreme-vue:build",
    "pack": "pnpm --workspace-root nx run devextreme-vue:pack",
    "test": "jest"
  },
  "keywords": [
    "Vue",
    "Vue grid",
    "vue-component",
    "devextreme",
    "devexpress",
    "UI",
    "UX",
    "component",
    "Components",
    "ui-components",
    "data grid",
    "datagrid",
    "data-grid",
    "data-table",
    "Grid",
    "Pivotgrid",
    "Pivot-grid",
    "Scheduler",
    "Gantt",
    "Diagram",
    "treelist",
    "chart",
    "Chat",
    "Editors",
    "Form",
    "File manager",
    "HTML-editor",
    "HTMLEditor",
    "AI",
    "Material-ui",
    "Fluent",
    "Responsive-ui",
    "Javascript",
    "Typescript",
    "shadowdom"
  ],
  "author": "Developer Express Inc.",
  "license": "MIT",
  "peerDependencies": {
    "devextreme": "workspace:*",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "catalog:",
    "@eslint-stylistic/metadata": "catalog:",
    "@eslint/eslintrc": "catalog:",
    "@eslint/js": "catalog:",
    "@stylistic/eslint-plugin": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@vue/compiler-sfc": "3.3.4",
    "@vue/shared": "3.4.26",
    "@vue/test-utils": "2.0.0-beta.7",
    "devextreme-metadata": "workspace:*",
    "eslint": "catalog:",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-config-airbnb-typescript": "catalog:",
    "eslint-config-devextreme": "catalog:",
    "eslint-plugin-i18n": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-no-only-tests": "catalog:",
    "eslint-plugin-spellcheck": "0.0.20",
    "eslint-plugin-vue": "catalog:",
