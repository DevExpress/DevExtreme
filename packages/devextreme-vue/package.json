    "ts-jest": "29.1.3",
    "typescript": "4.9.5",
    "vue": "3.2.47",
    "vue-eslint-parser": "catalog:",
    "vue-router": "4.2.5"
  },
  "publishConfig": {
    "directory": "npm",
    "linkDirectory": true
  }
