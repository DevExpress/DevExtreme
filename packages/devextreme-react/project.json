{
  "name": "devextreme-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/devextreme-react",
  "projectType": "library",
  "targets": {
    "clean:src": {
      "executor": "devextreme-nx-infra-plugin:clean",
      "options": {
        "targetDirectory": "./src",
        "excludePatterns": ["./src/core", "./src/common", "./src/index.ts"]
      }
    },
    "clean:npm": {
      "executor": "devextreme-nx-infra-plugin:clean",
      "options": {
        "targetDirectory": "./npm"
      }
    },
    "build:esm": {
      "executor": "devextreme-nx-infra-plugin:build-typescript",
      "options": {
        "srcPattern": "./src/**/*.{ts,tsx}",
        "excludePatterns": ["./src/**/__tests__/**/*", "./src/**/__mocks__/**/*"],
        "tsconfig": "./tsconfig.esm.json",
        "outDir": "./npm/esm",
        "module": "esm"
      },
      "outputs": ["{projectRoot}/npm/esm"],
      "inputs": ["default"]
    },
    "build:cjs": {
      "executor": "devextreme-nx-infra-plugin:build-typescript",
      "options": {
        "srcPattern": "./src/**/*.{ts,tsx}",
        "excludePatterns": ["./src/**/__tests__/**/*", "./src/**/__mocks__/**/*"],
        "tsconfig": "./tsconfig.json",
        "outDir": "./npm/cjs",
        "module": "cjs"
      },
      "outputs": ["{projectRoot}/npm/cjs"],
      "inputs": ["default"]
    },
    "prepare-package-json": {
      "executor": "devextreme-nx-infra-plugin:prepare-package-json",
    },
    "license-headers": {
      "executor": "devextreme-nx-infra-plugin:add-license-headers",
      "options": {
        "targetDirectory": "./npm",
        "packageJsonPath": "./package.json",
        "mode": "mit"
      }
    },
    "npm:prepare-modules": {
      "executor": "devextreme-nx-infra-plugin:prepare-submodules",
      "options": {
        "distDirectory": "./npm"
      }
    },
    "copy-files": {
      "executor": "devextreme-nx-infra-plugin:copy-files",
      "dependsOn": ["prepare-package-json"],
      "options": {
        "files": [
          {
            "from": "./LICENSE",
            "to": "./npm/LICENSE"
          },
          {
            "from": "./README.md",
            "to": "./npm/README.md"
          }
        ]
      }
    },
    "npm:pack": {
      "executor": "devextreme-nx-infra-plugin:pack-npm",
      "outputs": ["{projectRoot}/npm/*.tgz"],
      "inputs": ["default"]
   },
   "generate-components": {
      "executor": "devextreme-nx-infra-plugin:generate-components",
      "options": {
        "metadataPath": "../devextreme-metadata/dist/integration-data.json",
        "componentsDir": "./src",
        "indexFileName": "./src/index.ts",
        "baseComponent": "./core/component",
        "extensionComponent": "./core/extension-component",
        "configComponent": "./core/nested-option",
        "quotes": "double",
        "explicitIndexInImports": true
      },
      "outputs": [
        "{projectRoot}/src/**/*",
        "!{projectRoot}/src/core/**/*",
        "!{projectRoot}/src/common/**/*",
        "!{projectRoot}/src/**/__tests__/**/*"
      ],
      "inputs": ["default"]
    },
    "regenerate": {
      "executor": "nx:run-commands",
      "dependsOn": ["devextreme-metadata:generate"],
      "options": {
        "commands": [
          "pnpm --workspace-root nx clean:src devextreme-react",
          "pnpm --workspace-root nx generate-components devextreme-react"
        ],
        "parallel": false
      },
      "outputs": [
        "{projectRoot}/src/**/*",
        "!{projectRoot}/src/core/**/*",
        "!{projectRoot}/src/common/**/*",
        "!{projectRoot}/src/**/__tests__/**/*"
      ],
      "inputs": ["default"]
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "options": {
        "commands": [
          "pnpm --workspace-root nx clean:npm devextreme-react",
          "pnpm --workspace-root nx run-many --targets=build:esm,build:cjs --projects=devextreme-react",
          "pnpm --workspace-root nx copy-files devextreme-react",
          "pnpm --workspace-root nx npm:prepare-modules devextreme-react",
          "pnpm --workspace-root nx prepare-package-json devextreme-react"
        ],
        "parallel": false
      },
      "outputs": [
        "{projectRoot}/npm"
      ],
      "inputs": ["default"]
    },
    "pack": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm --workspace-root nx clean:npm devextreme-react",
          "pnpm --workspace-root nx run-many --targets=build:esm,build:cjs --projects=devextreme-react",
          "pnpm --workspace-root nx copy-files devextreme-react",
          "pnpm --workspace-root nx npm:prepare-modules devextreme-react",
          "pnpm --workspace-root nx prepare-package-json devextreme-react",
          "pnpm --workspace-root nx license-headers devextreme-react",
          "pnpm --workspace-root nx npm:prepare-modules devextreme-react",
          "pnpm --workspace-root nx npm:pack devextreme-react"
        ],
        "parallel": false
      },
      "outputs": [
        "{projectRoot}/npm",
        "{projectRoot}/npm/*.tgz"
      ],
      "inputs": ["default"]
    },
    "test": {
      "executor": "nx:run-script",
      "options": {
        "script": "test"
      },
      "inputs": [
        "default",
        "test"
      ]
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/src/**/*",
      "!{projectRoot}/src/**/__tests__/*",
      "{projectRoot}/tsconfig*",
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/packages/devextreme-metadata/**/*"
    ],
    "test": [
      "{projectRoot}/src/**/__tests__/*",
      "{projectRoot}/jest.config.js"
    ]
  },
  "tags": []
}
