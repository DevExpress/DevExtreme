{
  "name": "sbom",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["install-dependencies", "clean", "make-sbom"],
      "options": {
        "cwd": "{projectRoot}",
        "command": "cp dist/devextreme.sbom.json dist/devextreme-dist.sbom.json"
      },
      "cache": false
    },
    "install-dependencies": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm install --frozen-lockfile"
      },
      "cache": false
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "rm -rf dist/"
      },
      "cache": false
    },
    "make-sbom": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm dx-make-sbom ../../ dist/ devextreme,devextreme-react,devextreme-angular,devextreme-vue,devextreme-themebuilder"
      },
      "cache": false
    }
  }
}
