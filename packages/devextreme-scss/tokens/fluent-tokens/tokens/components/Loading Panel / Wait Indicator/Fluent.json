          "$type": "color"
        }
      },
      "light": {
        "loader": {
          "$value": "{color.content.neutral.static.rest}",
          "$type": "color"
        },
        "track": {
          "$value": "{color.content.neutral.static.rest}",
          "$type": "color"
        }
      },
      "dark": {
        "loader": {
          "$value": "{color.content.neutral.static-inverted.rest}",
          "$type": "color"
        },
        "track": {
          "$value": "{color.content.neutral.static-inverted.rest}",
          "$type": "color"
        }
      }
    },
    "layout": {
      "small": {
        "$value": "{sizing.160}",
