{
  "$schema": "https://json-schema.org/schema",
  "title": "Karma Multi Env Executor Schema",
  "description": "Run Karma tests sequentially across multiple Angular environments (client, server, hydration)",
  "type": "object",
  "properties": {
    "karmaConfig": {
      "type": "string",
      "description": "Path to karma.conf.js"
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["client", "server", "hydration"]
      },
      "default": ["client", "server", "hydration"]
    },
    "watch": {
      "type": "boolean",
      "default": false
    },
    "debug": {
      "type": "boolean",
      "default": false
    },
    "timeout": {
      "type": "number",
      "description": "Test timeout in milliseconds",
      "default": 300000
    },
    "verbose": {
      "type": "boolean",
      "description": "Enable verbose logging output",
      "default": false
    }
  },
  "required": ["karmaConfig"]
}
