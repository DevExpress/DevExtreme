{
  "$schema": "https://json-schema.org/schema",
  "title": "Clean Executor Schema",
  "description": "Clean directories with support for simple or recursive mode",
  "type": "object",
  "properties": {
    "targetDirectory": {
      "type": "string",
      "description": "Directory to clean",
      "default": "./src"
    },
    "excludePatterns": {
      "type": "array",
      "description": "Patterns to exclude from cleaning.",
      "items": {
        "type": "string"
      },
      "default": []
    }
  }
}
