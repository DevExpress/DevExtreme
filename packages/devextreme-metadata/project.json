{
  "name": "devextreme-metadata",
  "projectType": "library",
  "targets": {
    "discover-declarations": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm exec ts-node -T ./discover-declarations.ts"
      },
      "inputs": [
        "metadataToolsCommonInputs",
        "{workspaceRoot}/packages/devextreme/js/**/*.ts",
        "{workspaceRoot}/packages/devextreme/js/**/*.js"
      ],
      "outputs": [
        "{projectRoot}/dist/Declarations.json",
        "{projectRoot}/dist/devextreme-uml.wsd",
        "{projectRoot}/dist/modules-meta.json",
        "{projectRoot}/dist/ts-members-meta.json"
      ]
    },
    "make-angular-metadata": {
      "dependsOn": ["discover-declarations"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm exec ts-node -T ./make-angular-metadata.ts"
      },
      "inputs": [
        "metadataToolsCommonInputs",
        "{projectRoot}/dist/Declarations.json"
      ],
      "outputs": [
        "{projectRoot}/dist/NGMetaData.json"
      ]
    },
    "make-aspnet-metadata": {
      "dependsOn": ["discover-declarations"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm exec ts-node -T ./make-aspnet-metadata.ts"
      },
      "inputs": [
        "metadataToolsCommonInputs",
        "{projectRoot}/dist/Declarations.json"
      ],
      "outputs": [
        "{projectRoot}/dist/StrongMetaData.json"
      ]
    },
    "make-integration-metadata": {
      "dependsOn": ["discover-declarations"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm exec ts-node -T ./make-integration-metadata.ts"
      },
      "inputs": [
        "metadataToolsCommonInputs",
        "{projectRoot}/dist/Declarations.json"
      ],
      "outputs": [
        "{projectRoot}/dist/integration-data.json"
      ]
    },
    "generate": {
      "dependsOn": [
        "make-angular-metadata",
        "make-aspnet-metadata",
        "make-integration-metadata"
      ],
      "executor": "nx:noop",
      "inputs": [
        "{projectRoot}/dist/**"
      ]
    },
    "pack": {
      "dependsOn": ["generate"],
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "pnpm pack"
      },
      "inputs": [
        "{projectRoot}/dist/**",
        "{projectRoot}/package.json"
      ]
    }
  }
}
