{
  "name": "devextreme-angular",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/devextreme-angular",
  "projectType": "library",
  "implicitDependencies": [
    "devextreme"
  ],
  "targets": {
    "clean:src-metadata": {
      "executor": "devextreme-nx-infra-plugin:clean",
      "options": {
        "targetDirectory": "./src/metadata"
      }
    },
    "clean:src-ui": {
      "executor": "devextreme-nx-infra-plugin:clean",
      "options": {
        "targetDirectory": "./src/ui",
        "excludePatterns": [
          "./src/ui/popup/service",
          "./src/ui/popup/index.ts"
        ]
      }
    },
    "clean:dist": {
      "executor": "devextreme-nx-infra-plugin:clean",
      "options": {
        "targetDirectory": "./dist"
      }
    },
    "clean:npm": {
      "executor": "devextreme-nx-infra-plugin:clean",
      "options": {
        "targetDirectory": "./npm"
      }
    },
    "copy:build-sources": {
      "executor": "devextreme-nx-infra-plugin:copy-files",
      "options": {
        "files": [
          {
            "from": "./src",
            "to": "./dist"
          },
          {
            "from": "./package.json",
            "to": "./dist/package.json"
          },
          {
            "from": "./ng-package.json",
            "to": "./dist/ng-package.json"
          }
        ]
      },
      "outputs": [
        "{projectRoot}/dist"
      ],
      "inputs": [
        "default"
      ]
    },
    "build:license-headers": {
      "executor": "devextreme-nx-infra-plugin:add-license-headers",
      "dependsOn": [
        "copy:build-sources"
      ],
      "options": {
        "targetDirectory": "./dist",
        "packageJsonPath": "./package.json",
        "includePatterns": [
          "**/*.ts"
        ],
        "mode": "mit"
      }
    },
    "build:ngc": {
      "executor": "devextreme-nx-infra-plugin:build-angular-library",
      "options": {
        "project": "dist/ng-package.json",
        "tsConfig": "tsconfig.lib.json"
      },
      "outputs": [
        "{projectRoot}/npm/dist"
      ],
      "inputs": [
        "default"
      ]
    },
    "npm:content": {
      "executor": "devextreme-nx-infra-plugin:copy-files",
      "options": {
        "files": [
          {
            "from": "./LICENSE",
            "to": "./npm/dist/LICENSE"
          },
          {
            "from": "./README.md",
            "to": "./npm/dist/README.md"
          },
          {
            "from": "./src/schematics",
            "to": "./npm/dist/schematics"
          }
        ]
      }
    },
    "npm:package-json": {
      "executor": "devextreme-nx-infra-plugin:prepare-package-json",
      "dependsOn": [
        "npm:content"
      ],
      "options": {
        "sourcePackageJson": "./npm/dist/package.json",
        "distDirectory": "./npm/dist"
      }
    },
    "npm:pack-npm-dist": {
      "executor": "devextreme-nx-infra-plugin:pack-npm",
      "outputs": [
        "{projectRoot}/npm/dist/*.tgz"
      ],
      "inputs": [
        "default"
      ]
    },
    "update-node-modules-with-npm-dist": {
      "executor": "devextreme-nx-infra-plugin:copy-files",
      "options": {
        "files": [
          {
            "from": "./npm/dist",
            "to": "./node_modules/devextreme-angular"
          }
        ]
      },
      "outputs": [
        "{projectRoot}/node_modules/devextreme-angular/**/*"
      ],
      "inputs": [
        "default"
      ]
    },
    "generate-components": {
      "executor": "devextreme-nx-infra-plugin:generate-components",
      "options": {
        "framework": "angular",
        "generatorConfig": "angularConfig",
        "metadataPath": "../devextreme-metadata/dist/integration-data.json",
        "componentsDir": "./src/ui",
        "indexFileName": "./src/index.ts",
        "quotes": "single",
        "explicitIndexInImports": true,
        "excludePatterns": [
          "./src/ui/popup/service",
          "./src/ui/popup/index.ts"
        ]
      },
      "inputs": [
        "default"
      ],
      "outputs": [
        "{projectRoot}/src/ui/**/*",
        "!{projectRoot}/src/ui/popup/service/**/*",
        "!{projectRoot}/src/ui/popup/index.ts",
        "{projectRoot}/src/index.ts",
        "{projectRoot}/src/common/index.ts",
        "{projectRoot}/src/metadata/generated/**/*"
      ]
    },
    "regenerate": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "devextreme-metadata:generate"
      ],
      "options": {
        "commands": [
          "pnpm --workspace-root nx clean:src-metadata devextreme-angular",
          "pnpm --workspace-root nx clean:src-ui devextreme-angular",
          "pnpm --workspace-root nx generate-components devextreme-angular"
        ],
        "parallel": false
      },
      "outputs": [
        "{projectRoot}/src/ui/**/*",
        "!{projectRoot}/src/ui/popup/service/**/*",
        "!{projectRoot}/src/ui/popup/index.ts",
        "{projectRoot}/src/index.ts",
        "{projectRoot}/src/common/index.ts",
        "{projectRoot}/src/metadata/generated/**/*"
      ],
      "inputs": [
        "default"
      ]
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": [
        {
          "dependencies": true,
          "target": "build",
          "params": "forward"
        }
      ],
      "options": {
        "commands": [
          "pnpm --workspace-root nx clean:dist devextreme-angular",
          "pnpm --workspace-root nx copy:build-sources devextreme-angular",
          "pnpm --workspace-root nx build:license-headers devextreme-angular",
          "pnpm --workspace-root nx build:ngc devextreme-angular"
        ],
        "parallel": false
      },
      "outputs": [
        "{projectRoot}/",
        "{projectRoot}/npm/dist"
      ],
      "inputs": [
        "default"
      ],
      "configurations": {
        "testing": {
          "env": {
            "BUILD_TEST_INTERNAL_PACKAGE": "true"
          }
        }
      }
    },
    "pack": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm --workspace-root nx run-many --targets=clean:dist,clean:npm --projects=devextreme-angular",
          "pnpm --workspace-root nx copy:build-sources devextreme-angular",
          "pnpm --workspace-root nx build:license-headers devextreme-angular",
          "pnpm --workspace-root nx build:ngc devextreme-angular",
          "pnpm --workspace-root nx npm:content devextreme-angular",
          "pnpm --workspace-root nx npm:package-json devextreme-angular",
          "pnpm --workspace-root nx npm:pack-npm-dist devextreme-angular",
          "pnpm --workspace-root nx update-node-modules-with-npm-dist devextreme-angular"
        ],
        "parallel": false
      },
      "configurations": {
        "with-descriptions": {
          "commands": [
            "pnpm --workspace-root nx run-many --targets=clean:dist,clean:npm --projects=devextreme-angular",
            "pnpm --workspace-root nx copy:build-sources devextreme-angular",
            "pnpm --workspace-root nx build:license-headers devextreme-angular",
            "pnpm --workspace-root nx build:ngc devextreme-angular",
            "pnpm --workspace-root nx npm:content devextreme-angular",
            "pnpm --workspace-root nx npm:package-json devextreme-angular",
            "pnpm --workspace-root run angular:inject-descriptions",
            "pnpm --workspace-root nx npm:pack-npm-dist devextreme-angular",
            "pnpm --workspace-root nx update-node-modules-with-npm-dist devextreme-angular"
          ]
        }
      }
    },
    "generate-component-names-for-tests": {
      "executor": "devextreme-nx-infra-plugin:generate-component-names",
      "options": {
        "componentFilesPath": "./src/ui/",
        "excludedFileNames": [
          "nested",
          "validation-group",
          "validation-summary",
          "validator",
          "button-group",
          "drop-down-button",
          "file-manager"
        ],
        "outputFileName": "./tests/src/server/component-names.ts"
      },
      "inputs": [
        "default",
        "{projectRoot}/src/ui/**/*"
      ],
      "outputs": [
        "{projectRoot}/tests/src/server/component-names.ts"
      ]
    },
    "clean:tests": {
      "executor": "devextreme-nx-infra-plugin:clean",
      "options": {
        "targetDirectory": "./tests/dist"
      }
    },
    "build:tests": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm --workspace-root nx clean:tests devextreme-angular",
          "pnpm --workspace-root nx generate-component-names-for-tests devextreme-angular",
          "pnpm --workspace-root nx copy:dist-dx-angular-to-tests-dist devextreme-angular",
          "tsc --project tsconfig.tests.json --outDir tests/dist"
        ],
        "cwd": "packages/devextreme-angular",
        "parallel": false
      },
      "inputs": [
        "default",
        "test",
        "{projectRoot}/tests/src/server/component-names.ts"
      ],
      "outputs": [
        "{projectRoot}/tests/dist/**/*",
        "{projectRoot}/tests/dist/**/*.js.map"
      ]
    },
    "copy:dist-dx-angular-to-tests-dist": {
      "executor": "devextreme-nx-infra-plugin:copy-files",
      "options": {
        "files": [
          {
            "from": "./npm/dist",
            "to": "./tests/dist/node_modules/devextreme-angular"
          }
        ]
      },
      "inputs": [
        "{projectRoot}/npm/dist/**/*"
      ],
      "outputs": [
        "{projectRoot}/tests/dist/node_modules/devextreme-angular"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "pnpm --workspace-root nx build devextreme-angular -c testing",
          "pnpm --workspace-root nx build:tests devextreme-angular",
          "pnpm --workspace-root nx test:all devextreme-angular"
        ],
        "parallel": false,
        "cwd": "packages/devextreme-angular"
      },
      "inputs": [
        "test"
      ]
    },
    "test:all": {
      "executor": "devextreme-nx-infra-plugin:karma-multi-env",
      "options": {
        "karmaConfig": "karma.conf.js",
        "environments": [
          "client",
          "server",
          "hydration"
        ]
      },
      "dependsOn": [
        "build:tests"
      ],
      "inputs": [
        "default",
        "test",
        "{projectRoot}/tests/dist/**/*"
      ]
    },
    "test:components-client": {
      "executor": "devextreme-nx-infra-plugin:karma-multi-env",
      "options": {
        "karmaConfig": "karma.conf.js",
        "environments": [
          "client"
        ]
      },
      "dependsOn": [
        "build:tests"
      ],
      "inputs": [
        "default",
        "test",
        "{projectRoot}/tests/dist/**/*"
      ]
    },
    "test:components-client-debug": {
      "executor": "devextreme-nx-infra-plugin:karma-multi-env",
      "options": {
        "karmaConfig": "karma.conf.js",
        "environments": [
          "client"
        ],
        "debug": true
      },
      "dependsOn": [
        "build:tests"
      ]
    },
    "test:components-server": {
      "executor": "devextreme-nx-infra-plugin:karma-multi-env",
      "options": {
        "karmaConfig": "karma.conf.js",
        "environments": [
          "server",
          "hydration"
        ]
      },
      "dependsOn": [
        "build:tests"
      ],
      "inputs": [
        "default",
        "test",
        "{projectRoot}/tests/dist/**/*"
      ]
    },
    "test:components-server-debug": {
      "executor": "devextreme-nx-infra-plugin:karma-multi-env",
      "options": {
        "karmaConfig": "karma.conf.js",
        "environments": [
          "server"
        ],
        "debug": true
      },
      "dependsOn": [
        "build:tests"
      ],
      "inputs": [
        "default",
        "test",
        "{projectRoot}/tests/dist/**/*"
      ]
    },
    "watch:test": {
      "executor": "devextreme-nx-infra-plugin:karma-multi-env",
      "options": {
        "karmaConfig": "karma.conf.js",
        "watch": true,
        "environments": [
          "client"
        ]
      },
      "dependsOn": [
        "build:tests"
      ],
      "inputs": [
        "default",
        "test",
        "{projectRoot}/tests/dist/**/*"
      ]
    },
    "run:tests": {
      "executor": "devextreme-nx-infra-plugin:karma-multi-env",
      "options": {
        "karmaConfig": "karma.conf.js",
        "environments": [
          "client",
          "server",
          "hydration"
        ]
      },
      "dependsOn": [
        "build:tests"
      ],
      "inputs": [
        "default",
        "test",
        "{projectRoot}/tests/dist/**/*"
      ]
    },
    "watch:spec": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc --project tsconfig.tests.json --outDir tests/dist --watch"
        ],
        "parallel": false,
        "cwd": "packages/devextreme-angular"
      },
      "inputs": [
        "test"
      ]
    }
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/src/**/*",
      "!{projectRoot}/src/**/__tests__/*",
      "{projectRoot}/ng-package.json",
      "{projectRoot}/tsconfig.json",
      "{projectRoot}/tsconfig.lib.json",
      "{projectRoot}/package.json",
      "{projectRoot}/metadata/**/*",
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/tools/generators-config.js",
      "{workspaceRoot}/packages/devextreme-metadata/**/*"
    ],
    "test": [
      "{projectRoot}/tests/**/*",
      "{projectRoot}/karma.conf.js",
      "{projectRoot}/karma.test.shim.js",
      "{projectRoot}/karma.server.test.shim.js",
      "{projectRoot}/karma.hydration.test.shim.js",
      "{projectRoot}/webpack.test.js",
      "{projectRoot}/tsconfig.tests.json",
      "{projectRoot}/src/**/*.spec.ts",
      "{projectRoot}/src/**/*.test.ts"
    ]
  },
  "tags": []
}
