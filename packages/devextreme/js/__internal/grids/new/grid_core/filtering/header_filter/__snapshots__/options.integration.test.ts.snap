          <div
            class="dx-scrollable-scrollbar dx-widget dx-scrollbar-horizontal"
            style="display: none;"
          >
            <div
              class="dx-scrollable-scroll dx-state-invisible"
            >
              <div
                class="dx-scrollable-scroll-content"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
    
