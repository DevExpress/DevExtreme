          class="dx-scrollable-container"
        >
          <div
            class="dx-scrollable-content"
            style="left: 0px; top: 0px; transform: none;"
          >
            <div
              data-dx-focus-container="true"
            >
              <div
                data-dx-focus-decoy="true"
                tabindex="0"
              />
              <div
                class="dx-cardview-headerpanel-content dx-cardview-headerpanel-content--with-header-items"
                role="menubar"
              >
                <div
                  class="dx-cardview-header-item-container"
                >
                  <div
                    aria-label="Field name A"
                    class="dx-cardview-header-item  "
                    role="menuitem"
                    tabindex="0"
                  >
                    A
                    <div
                      class="dx-icon dx-icon-filter dx-header-filter-icon "
                    />
                  </div>
                </div>
              </div>
              <div
                data-dx-focus-decoy="true"
                tabindex="0"
              />
