@model RunAllViewModel
<!DOCTYPE html>

<head>
    <title>QUnit All Suites test page</title>
    <meta name="MobileOptimized" content="480">
</head>

<style>
    html, body
    {
        height: 100%;
    }

    body
    {
        padding: 0;
        margin: 0;
        background: gray;
    }

    iframe
    {
        background: white;
    }

    #workers .worker
    {
        float: left;
        margin: 4px;
    }

    #workers .worker iframe
    {

        width: 400px;
        height: 300px;
        border: solid 2px black;
    }

    #reportFrame
    {
        border: 0;
        width: 100%;
        height: 100%;
        display: none;
    }

    h1, h2 {
        margin: 0;
        padding: 0;
    }

</style>

<script src="@Url.Content("~/packages/devextreme/artifacts/js/jquery.js")"></script>

<script>
    $(function() {
        var ROOT_URL = "@Url.Content("~/")";

        // Set global AJAX timeout to prevent hanging requests
        $.ajaxSetup({
            timeout: 30000 // 30 seconds timeout for all AJAX requests
        });

        // Send important logs to server for CI debugging
        var serverLog = function(message) {
            console.log(message); // Also log to browser console
            
            // Send to server if in CI mode
            if(@Html.Raw(Json.Serialize(Model.IsContinuousIntegration))) {
                $.post(@Html.Raw(Json.Serialize(Url.Action("LogMiscError"))), { 
                    msg: "[JS] " + message,
                    timeout: 5000 // Short timeout for logging
                }).fail(function() {
                    // Silently ignore failures to avoid recursion
                });
            }
        };

        var TEST_TIMEOUT_SECONDS = 45,
            TEST_TIMEOUT = TEST_TIMEOUT_SECONDS * 1000,
            WORKER_STUCK_TIMEOUT = 60 * 1000, // 60 seconds without any activity
            WORKER_NAME_PREFIX = "workerFrame",
            busyCount = 0,
            suitesDescription = {
                constellation: "@(Model.Constellation)",
                categoriesList: "@(Model.CategoriesList)",
                version: "@(Model.Version)"
            },
            suitesInProgress = [ ],
            workerLastActivity = [ ], // Track last activity time for each worker
            urls = @Html.Raw(Json.Serialize(Model.Suites)),
            originalUrls = urls.slice(0),
            noTryCatch = @Html.Raw(Json.Serialize(Model.NoTryCatch)),
            noGlobals = @Html.Raw(Json.Serialize(Model.NoGlobals)),
            noTimers = @Html.Raw(Json.Serialize(Model.NoTimers)),
            noJQuery = @Html.Raw(Json.Serialize(Model.NoJQuery)),
            shadowDom = @Html.Raw(Json.Serialize(Model.ShadowDom)),
            noCsp = @Html.Raw(Json.Serialize(Model.NoCsp)),
            farmMode = @Html.Raw(Json.Serialize(Model.IsContinuousIntegration)),
            DX_HTTP_CACHE = Date.now(),
            runWorkerInNewWindow = @Html.Raw(Json.Serialize(Model.WorkerInWindow)),
            maxWorkersFromEnv = @Html.Raw(Json.Serialize(Model.MaxWorkers)),

            WORKER_COUNT;

        var calcWorkerFrameCount = function() {
            if(runWorkerInNewWindow)
                return 1; // NOTE: more than 1 window cause problems with tests that use focus

            // Use MAX_WORKERS from environment variable if set
            if(maxWorkersFromEnv !== null && maxWorkersFromEnv > 0)
                return maxWorkersFromEnv;

            return 2;
        };

        WORKER_COUNT = calcWorkerFrameCount();

        var testResults = {
            name: "QUnit runner output",
            total: 0,
            failures: 0,
            suites: [
                {
                    __type: "suite",
                    name: "Root suite",
                    results: [ ],
                    pureTime: 0
                }
            ]
        };

        var rootSuite = testResults.suites[0],
            rootStartTime = new Date();

        var titleElement  = document.getElementById("title");
        if(suitesDescription.constellation) {
            titleElement.innerText = suitesDescription.constellation;
            titleElement.style.color = "yellow";
        } else {
            titleElement.innerText = suitesDescription.categoriesList;
            titleElement.style.color = "white";
        }

        document.getElementById("branch").innerText = suitesDescription.version;


        var saveResults = function() {
            $.ajax({
                url: @Html.Raw(Json.Serialize(Url.Action("SaveResults"))),
                type: "post",
                contentType: "application/json",
                data: JSON.stringify(testResults),
                timeout: 60000 // 60 second timeout for saving results
            }).done(function() {
                notifyDeviceTestManager("QUnit.saveResults.done");
                removeWorkers();

                var frame = document.getElementById("reportFrame");
                frame.style.display = "block";
                frame.setAttribute("src", @Html.Raw(Json.Serialize(Url.Action("DisplayResults"))));
            }).fail(function(jqXHR, textStatus, errorThrown) {
                serverLog('SaveResults FAILED: ' + textStatus + ' ' + errorThrown);
                // Try to continue anyway
                notifyDeviceTestManager("QUnit.saveResults.failed");
                removeWorkers();
            });
        };

        var resultSaving = false;

        var nextUrl = function(i) {
            console.log('nextUrl: worker=' + i + ', urls.length=' + urls.length + ', busyCount=' + busyCount + 
                ', currentSuite=' + (suitesInProgress[i] ? suitesInProgress[i].name : 'null'));
            
            // Safety check: if worker is still busy, do not load next test
            if(suitesInProgress[i] !== null && suitesInProgress[i] !== undefined) {
                serverLog('ERROR: nextUrl called but worker ' + i + ' is still busy with ' + suitesInProgress[i].name + '! Skipping.');
                return;
            }
            
            if(!urls.length) {
                console.log('nextUrl: No more URLs for worker ' + i);
                // $.ajax(ROOT_URL + "run/something/FrameHasFinishedRunningASuite.js?frame=" + i);
                if(!resultSaving && !busyCount) {
                    console.log('All tests completed, saving results...');
                    resultSaving = true;
                    rootSuite.time = roundTime((new Date() - rootStartTime) / 1000);
                    rootSuite.pureTime = roundTime(rootSuite.pureTime);
                    saveResults();
                    window.onbeforeunload = $.noop;
                } else {
                    console.log('Waiting for tests to complete: resultSaving=' + resultSaving + ', busyCount=' + busyCount);
                    if(busyCount < 0) {
                        console.error('ERROR: busyCount is negative! This should not happen.');
                    }
                    
                    // Debug: show which workers are still busy
                    var busyWorkers = [];
                    for(var w = 0; w < WORKER_COUNT; w++) {
                        if(suitesInProgress[w]) {
                            busyWorkers.push('Worker' + w + ':' + suitesInProgress[w].name);
                        }
                    }
                    if(busyWorkers.length > 0) {
                        console.log('Busy workers: ' + busyWorkers.join(', '));
                    }
                }
                return;
            }

            notifyDeviceTestManager("QUnit.nextUrl");

            var that = this,
                _i = i,
                urlInfo = urls.shift(),
                worker = workerByIndex(i),
                additionalParams = { };

            if(noTryCatch)
                additionalParams.notrycatch = "true";
            if(noGlobals)
                additionalParams.noglobals = "true";
            if(noTimers)
                additionalParams.notimers = "true";
            if(noJQuery)
                additionalParams.nojquery = "true";
            if(shadowDom)
                additionalParams.shadowDom = "true";
            if(noCsp) {
                additionalParams.nocsp = "true";
            }

            additionalParams.DX_HTTP_CACHE = DX_HTTP_CACHE;
            additionalParams.frame = i;

            suitesInProgress[i] = {
                __type: "suite",

                name: urlInfo.FullName,
                url: urlInfo.Url,
                results: [ ],

                startTime: new Date(),
                pureTime: 0,
                finalized: false, // Track if suite has been finalized

                finalize: function(success) {
                    if(this.finalized) {
                        serverLog('Suite already finalized: ' + this.name + ', skipping duplicate finalize');
                        return;
                    }
                    
                    var suiteName = this.name; // Save name before cleanup
                    serverLog('===== FINALIZE CALLED for ' + suiteName + ' =====');
                    
                    this.finalized = true;
                    this.time = roundTime((new Date() - this.startTime) / 1000);
                    this.pureTime = roundTime(this.pureTime);
                    delete this.startTime;

                    delete this.finalize;
                    delete this.url;

                    rootSuite.results.push(this);
                    suitesInProgress[i] = null;
                    busyCount--;
                    
                    serverLog('Suite finalized: ' + suiteName + ', worker=' + _i + ', busyCount=' + busyCount);
                    
                    // NOTE: Do NOT call nextUrl here! 
                    // It will be called after notifySuiteFinalized completes (or fails) 
                    // to ensure proper sequencing
                }
            };

            worker.name = WORKER_NAME_PREFIX + i;
            busyCount++;
            console.log('Loading test in worker ' + i + ': ' + urlInfo.FullName + ', busyCount=' + busyCount + 
                ', urls remaining=' + urls.length);
            worker.location = urlInfo.Url + "?" + $.param(additionalParams);
            workerLastActivity[i] = Date.now(); // Mark worker as active
        };

        var workers = [ ];

        var createWorkers = function() {
            var worker;

            for(var i = 0; i < WORKER_COUNT; i++) {
                if(runWorkerInNewWindow) {
                    worker = window.open("about:blank", "popup" + Date.now(), "left=0,top=0,width=500,height=500");
                } else {
                    var workerWrapper = $("<div class=worker></div>")
                        .attr("id", "worker" + i)
                        .append(
                            $("<iframe scrolling=no></iframe")
                        )
                        .appendTo("#workers")

                    worker = workerWrapper.children("iframe").get(0).contentWindow;
                }
                workers.push(worker);
            }
        };

        var removeWorkers = function() {
            if(runWorkerInNewWindow) {
                for(var i = 0; i < workers.length; i++) {
                    workers[i].close();
                };
            } else {
                $("#workers").remove();
            }
            workers = [];
        };

        var workerByIndex = function(index) {
            return workers[index];
        };

        var checkStuckWorkers = function() {
            var now = Date.now();
            var activeWorkers = [];
            
            for(var i = 0; i < WORKER_COUNT; i++) {
                var lastActivity = workerLastActivity[i];
                var suite = suitesInProgress[i];
                
                if(suite && !suite.finalized) {
                    var inactiveSeconds = Math.round((now - lastActivity) / 1000);
                    activeWorkers.push('Worker' + i + ':' + suite.name + '(' + inactiveSeconds + 's)');
                    
                    if(lastActivity && (now - lastActivity) > WORKER_STUCK_TIMEOUT) {
                        serverLog('ERROR: Worker ' + i + ' is STUCK on test: ' + suite.name + ' (no activity for ' + 
                            inactiveSeconds + ' seconds), busyCount=' + busyCount);
                        serverLog('Force finalizing stuck worker ' + i + ' and loading next test');
                        
                        // Force finalize the stuck suite (finalize checks for double-finalization)
                        suite.finalize(false); // Mark as failed
                        
                        // Clear worker state
                        suitesInProgress[i] = null;
                        workerLastActivity[i] = now;
                        
                        // Try to reload the worker by loading next test
                        var worker = workerByIndex(i);
                        if(worker) {
                            try {
                                // Force stop any running tests in the iframe
                                if(worker.contentWindow && worker.contentWindow.stop) {
                                    worker.contentWindow.stop();
                                }
                            } catch(e) {
                                serverLog('Could not stop worker iframe: ' + e.message);
                            }
                            
                            // Load next test
                            setTimeout(function() {
                                serverLog('Loading next test for recovered worker ' + i);
                                nextUrl(i);
                            }, 100);
                        }
                    }
                }
            }
            
            if(activeWorkers.length > 0 || busyCount > 0) {
                console.log('checkStuckWorkers: busyCount=' + busyCount + ', active: [' + activeWorkers.join(', ') + ']');
            }
        };

        var indexFromWorkerName = function(worker) {
            return Number(worker.name.substr(WORKER_NAME_PREFIX.length));
        };

        var runFirstBatch = function() {
            notifyDeviceTestManager("QUnit.runFirstBatch");
            for(var i = 0; i < WORKER_COUNT; i++)
                nextUrl(i);
        };

        var getTestCaseName = function(testSuite, qunitData) {
            var result = testSuite.name + " - ";
            if(qunitData.module)
                result += qunitData.module + ": ";
            result += qunitData.name;
            return result;
        };

        var getTestCaseUrl = function(testSuite, qunitData) {
            return testSuite.url + "?filter=" + encodeURIComponent(qunitData.name);
        };

        window.RUNNER_ON_TEST_START = function(worker, qunitData) {
            var i = indexFromWorkerName(worker),
                testSuite = suitesInProgress[i];

            workerLastActivity[i] = Date.now(); // Mark worker activity
            notifyIsAlive();

            var testCase = {
                __type: "case",

                startTime: new Date(),
                currentAssert: 0,

                stopWatch: launchStopWatch(),

                finalize: function(success) {
                    clearTimeout(this.stopWatch);
                    delete this.stopWatch;

                    var time = (new Date() - this.startTime) / 1000;
                    this.time = this.time || time;

                    testSuite.pureTime += time;
                    rootSuite.pureTime += time;

                    testResults.total++;
                    if(!success) {
                        testResults.failures++;
                    }

                    delete this.startTime;
                    delete this.currentAssert;
                    delete this.finalize;
                }
            };

            function launchStopWatch() {
                return setTimeout(function() {
                    testCase.finalize(false, 0);
                    testCase.name = getTestCaseName(testSuite, qunitData);
                    testCase.url = getTestCaseUrl(testSuite, qunitData);
                    testCase.failure = testCase.failure || { };
                    testCase.failure.message = "Test timed out after " + TEST_TIMEOUT_SECONDS + " seconds!";
                    testSuite.finalize(false, 0);
                }, TEST_TIMEOUT);
            }

            if(testSuite) {
                testSuite.results.push(testCase);
            } else {
                window.RUNNER_ON_MISC_ERROR(qunitData.suiteUrl,
                    "The test suite has already been finalized when an test has executed in the following test" +
                    "\nModule: " + qunitData.module +
                    "\nTest: " + qunitData.name + "\n" +
                    new Error().stack
                );
            }

            $.post(@Html.Raw(Json.Serialize(Url.Action("NotifyTestStarted"))), { name: getTestCaseName(testSuite, qunitData) })
                .fail(function(jqXHR, textStatus, errorThrown) {
                    console.warn('NotifyTestStarted failed:', textStatus, errorThrown);
                });
        };

        var indicateTestStatusInTitle = function(failed) {
            document.title = [
                    (failed ? "\u2716" : "\u2714"),
                    document.title.replace(/^[\u2714\u2716] /i, "")
            ].join(" ");
        };

        window.RUNNER_ON_TEST_LOG = function(worker, qunitData) {
            var i = indexFromWorkerName(worker),
                testSuite = suitesInProgress[i];

            if(testSuite && StringEndsWith(qunitData.suiteUrl, escape(testSuite.name))) {
                var testCases = testSuite.results,
                    testCase = testCases[testCases.length - 1];

                ++testCase.currentAssert;
                if(!qunitData.result) {
                    testCase.failure = testCase.failure || { message: "" };
                    testCase.failure.message += testCase.currentAssert + ". " + (qunitData.message || "failed") + "\n";
                    if(qunitData.hasOwnProperty("actual") && qunitData.hasOwnProperty("expected")) {
                        testCase.failure.message += "Expected: " + JSON.stringify(qunitData.expected) + "\n"
                                                  + "Result: " + JSON.stringify(qunitData.actual) + "\n"
                    }
                    testCase.failure.message += "Source:\n" + qunitData.source + "\n\n";
                    testCase.name = getTestCaseName(testSuite, qunitData);
                    testCase.url = getTestCaseUrl(testSuite, qunitData);

                    testCase.failure.message = stripDXCache(testCase.failure.message);

                    indicateTestStatusInTitle(!qunitData.failed);
                }
                else if(qunitData.message && qunitData.message.indexOf && qunitData.message.indexOf("TIME: ") === 0 && qunitData.actual){
                    testCase.name = getTestCaseName(testSuite, qunitData);
                    testCase.time = qunitData.actual;
                }
            } else {
                window.RUNNER_ON_MISC_ERROR(qunitData.suiteUrl,
                       "The test suite has already been finalized when an assert has executed in the following test" +
                       "\nModule: " + qunitData.module +
                       "\nTest: " + qunitData.name + "\n" +
                       new Error().stack
                );
            }
        };

        window.RUNNER_ON_TEST_DONE = function(worker, qunitData) {

            var i = indexFromWorkerName(worker),
                testSuite = suitesInProgress[i],
                testCases,
                testCase;

            workerLastActivity[i] = Date.now(); // Mark worker activity
            
            // Always notify on test done (removed throttling to prevent stalling)
            notifyDeviceTestManager("QUnit.testCaseDone");
            notifyIsAlive();

            if(testSuite && StringEndsWith(qunitData.suiteUrl, escape(testSuite.name))) {
                testCases = suitesInProgress[i].results;
                testCase = testCases[testCases.length - 1];

                if(qunitData.skipped) {
                    var reason = "Unknown reason",
                        name = qunitData.name;

                    if(name.indexOf("[") > -1) {
                        reason = name.substring(name.indexOf("[") + 1, name.indexOf("]"));
                        name = name.substring(0, name.indexOf("["));
                    }
                    testCase.reason = { message: reason };
                    qunitData.name = name;
                    testCase.name = getTestCaseName(testSuite, qunitData);
                    testCase.url = getTestCaseUrl(testSuite, qunitData);
                    testCase.executed = false;
                }
                testCase.finalize(!qunitData.failed, qunitData.total);
            } else {
                window.RUNNER_ON_MISC_ERROR(qunitData.suiteUrl,
                    "The test suite has already been finalized when the following test has finished running" +
                    "\nModule: " + qunitData.module +
                    "\nTest: " + qunitData.name + "\n" +
                    new Error().stack
                );
            }

            $.post(@Html.Raw(Json.Serialize(Url.Action("NotifyTestCompleted"))), { name: getTestCaseName(testSuite, qunitData), passed:  qunitData.passed === qunitData.total})
                .fail(function(jqXHR, textStatus, errorThrown) {
                    console.warn('NotifyTestCompleted failed:', textStatus, errorThrown);
                });
        };

        window.RUNNER_ON_DONE = function(worker, qunitData) {
            serverLog('===== RUNNER_ON_DONE CALLED =====');
            
            var i = indexFromWorkerName(worker),
                suite = suitesInProgress[i],
                passed = !qunitData.failed;

            serverLog('RUNNER_ON_DONE: worker=' + i + ', suite=' + (suite ? suite.name : 'null') + 
                ', busyCount=' + busyCount + ', failed=' + qunitData.failed + ', total=' + qunitData.total);

            if(suite) {
                if(suite.finalized) {
                    console.error('RUNNER_ON_DONE: suite ' + suite.name + ' is already finalized but still in suitesInProgress[' + i + ']!');
                    // This should not happen, but clean up just in case
                    suitesInProgress[i] = null;
                    return; // Do NOT call nextUrl - finalize() already did
                }
                
                var suiteName = suite.name; // Save before finalize clears it
                serverLog('RUNNER_ON_DONE: About to finalize suite ' + suiteName + ' (worker=' + i + ')');
                
                // finalize() handles busyCount-- internally and prevents double-finalization
                suite.finalize(passed, qunitData.total);
                
                serverLog('RUNNER_ON_DONE: About to notify server about ' + suiteName + ' completion');
                console.log('[CLIENT] RUNNER_ON_DONE: calling notifySuiteFinalized for ' + suiteName + ', worker=' + i);
                
                // Notify server and only then proceed to next test
                notifySuiteFinalized(suiteName, passed, qunitData.runtime, function() {
                    // Success or error - either way, continue to next test
                    console.log('[CLIENT] RUNNER_ON_DONE: callback fired for ' + suiteName + ', worker=' + i);
                    serverLog('RUNNER_ON_DONE: Server notified about ' + suiteName + ', calling nextUrl for worker ' + i);
                    
                    setTimeout(function() {
                        console.log('[CLIENT] RUNNER_ON_DONE: setTimeout fired, calling nextUrl for worker ' + i);
                        nextUrl.call(window, i);
                        console.log('[CLIENT] RUNNER_ON_DONE: nextUrl called for worker ' + i);
                    }, 0);
                });
            } else {
                console.warn('RUNNER_ON_DONE: suite is null for worker ' + i + ' - already finalized, skipping nextUrl call');
                // Suite is null - it was already finalized and nextUrl was already scheduled
                // Do NOT call nextUrl again to avoid loading tests twice in the same worker
            }
        };

        window.RUNNER_ON_MISC_ERROR = function(worker, msg) {
            msg = String(worker.location || worker) + ": " + msg;
            $.post(@Html.Raw(Json.Serialize(Url.Action("LogMiscError"))), { msg: msg });
        };

        window.onbeforeunload = function(e) {
            if(!isWinPhone) {
                var confirmationMessage = "Tests are Running!";
                (e || window.event).returnValue = confirmationMessage;
                return confirmationMessage;
            }
        };

        function StringEndsWith(phrase, ending) {
            return phrase.indexOf(ending, phrase.length - ending.length) !== -1;
        };

        function stripDXCache(text) {
            return String(text).replace(/[?&]DX_HTTP_CACHE=\w+/g, "");
        }

        function notifyDeviceTestManager(text) {
            if(window.external && "notify" in external) {
                external.notify(text);
            } else if("DevExtremeTestWorkerBridge" in window) {
                DevExtremeTestWorkerBridge.notify(text);
            }
        }

        // Queue for suite finalization to prevent AJAX flood
        var activeFinalizationRequests = 0;
        var maxConcurrentFinalizations = 3; // Max 3 simultaneous POST requests
        var finalizationQueue = [];
        
        function notifySuiteFinalized(name, passed, runtime, callback) {
            // Add to queue
            finalizationQueue.push({ name: name, passed: passed, runtime: runtime, callback: callback });
            processFinalizationQueue();
        }
        
        function processFinalizationQueue() {
            // Process queue if we have capacity
            while (finalizationQueue.length > 0 && activeFinalizationRequests < maxConcurrentFinalizations) {
                var item = finalizationQueue.shift();
                executeNotifySuiteFinalized(item.name, item.passed, item.runtime, item.callback);
            }
        }
        
        function executeNotifySuiteFinalized(name, passed, runtime, callback) {
            activeFinalizationRequests++;
            serverLog('notifySuiteFinalized: Sending POST for ' + name + ' (active=' + activeFinalizationRequests + ', queued=' + finalizationQueue.length + ')');
            console.log('[CLIENT] notifySuiteFinalized START for ' + name);
            
            var callbackCalled = false;
            var safeCallback = function(source) {
                if(callbackCalled) {
                    console.warn('[CLIENT] Callback already called for ' + name + ', ignoring duplicate from ' + source);
                    return;
                }
                callbackCalled = true;
                serverLog('notifySuiteFinalized: Calling callback for ' + name + ' (source: ' + source + ')');
                
                if(callback) {
                    console.log('[CLIENT] About to call callback for ' + name);
                    try {
                        callback();
                        console.log('[CLIENT] Callback executed successfully for ' + name);
                    } catch(e) {
                        console.error('[CLIENT] Callback threw exception for ' + name + ': ' + e.message);
                        serverLog('ERROR: Callback exception for ' + name + ': ' + e.message);
                    }
                } else {
                    console.log('[CLIENT] No callback provided for ' + name);
                }
            };
            
            // Safety timeout: force callback even if AJAX never completes
            // CI environments (Docker + headless Chrome) are much slower, use longer timeouts
            var ajaxTimeout = farmMode ? 60000 : 15000; // 60 sec for CI, 15 sec local
            var safetyTimeout = farmMode ? 90000 : 20000; // 90 sec for CI, 20 sec local
            
            var safetyTimer = setTimeout(function() {
                serverLog('WARNING: AJAX timeout for ' + name + ' after ' + safetyTimeout + 'ms, forcing callback');
                
                // Decrement active counter even on timeout
                activeFinalizationRequests--;
                
                safeCallback('safety-timeout');
                
                // Process next item in queue
                processFinalizationQueue();
            }, safetyTimeout);
            
            var ajaxRequest = $.ajax({
                url: @Html.Raw(Json.Serialize(Url.Action("NotifySuiteFinalized"))),
                type: 'POST',
                data: { name: name, passed: passed, runtime: runtime },
                timeout: ajaxTimeout
            });
            
            ajaxRequest.done(function() {
                serverLog('notifySuiteFinalized: Server responded OK for ' + name);
                console.log('[CLIENT] AJAX done for ' + name);
            });
            
            ajaxRequest.fail(function(jqXHR, textStatus, errorThrown) {
                var errorMsg = 'NotifySuiteFinalized FAILED for ' + name + 
                    ': status=' + textStatus + 
                    ', error=' + errorThrown + 
                    ', httpStatus=' + jqXHR.status + 
                    ', responseText=' + (jqXHR.responseText || 'none');
                serverLog(errorMsg);
                console.error('[CLIENT] AJAX fail for ' + name + ': ' + errorMsg);
            });
            
            ajaxRequest.always(function(dataOrJqXHR, textStatus) {
                // This ALWAYS runs, regardless of success or failure (unless process killed)
                console.log('[CLIENT] AJAX always for ' + name + ', status=' + textStatus);
                clearTimeout(safetyTimer); // Cancel safety timeout since AJAX completed
                
                // Decrement active counter and process next in queue
                activeFinalizationRequests--;
                serverLog('notifySuiteFinalized: Request complete for ' + name + ' (active=' + activeFinalizationRequests + ', queued=' + finalizationQueue.length + ')');
                
                safeCallback('ajax-always');
                
                // Process next item in queue
                processFinalizationQueue();
            });
            
            console.log('[CLIENT] executeNotifySuiteFinalized END (async) for ' + name);
        }
        // Throttle notifyIsAlive to prevent AJAX flood
        var lastAliveTime = 0;
        var aliveThrottleMs = 5000; // Minimum 5 seconds between alive pings
        var pendingAlive = false;
        
        function notifyIsAlive(){
            var now = Date.now();
            var timeSinceLastAlive = now - lastAliveTime;
            
            // If called too frequently, ignore (throttle)
            if (timeSinceLastAlive < aliveThrottleMs) {
                if (!pendingAlive) {
                    // Schedule one for later
                    pendingAlive = true;
                    setTimeout(function() {
                        pendingAlive = false;
                        notifyIsAlive();
                    }, aliveThrottleMs - timeSinceLastAlive);
                }
                return;
            }
            
            lastAliveTime = now;
            serverLog('[ALIVE] Sending NotifyIsAlive ping (throttled)');
            
            $.ajax({
                url: @Html.Raw(Json.Serialize(Url.Action("NotifyIsAlive"))),
                type: 'POST',
                timeout: farmMode ? 30000 : 10000 // 30 sec for CI, 10 sec local
            })
            .done(function() {
                serverLog('[ALIVE] NotifyIsAlive ping successful');
            })
            .fail(function(jqXHR, textStatus, errorThrown) {
                serverLog('[ALIVE] NotifyIsAlive FAILED: ' + textStatus + ', status=' + jqXHR.status);
            });
        }

        // Check for stuck workers every 15 seconds
        setInterval(checkStuckWorkers, 15000);
        
        // Log overall state every 10 seconds for debugging
        setInterval(function() {
            var activeSuites = [];
            for(var i = 0; i < WORKER_COUNT; i++) {
                if(suitesInProgress[i]) {
                    activeSuites.push('Worker' + i + ':' + suitesInProgress[i].name);
                }
            }
            
            // Only log to server if there are active suites or issues
            if(activeSuites.length > 0 || busyCount > 0 || (urls.length === 0 && !resultSaving)) {
                var stateMsg = '===== STATE: busyCount=' + busyCount + ', urls=' + urls.length + 
                    ', resultSaving=' + resultSaving + ', active=' + (activeSuites.length > 0 ? activeSuites.join('; ') : 'none');
                serverLog(stateMsg);
            }
        }, 10000);

        function roundTime(time) {
            return +(time.toFixed(3));
        }

        createWorkers();
        
        setInterval(function() {
            notifyIsAlive();
        }, 30000); // Reduced from 60000ms to 30000ms (30 seconds) to prevent watchdog timeout
        
        var mode = farmMode ? 'CI' : 'LOCAL';
        var ajaxTimeouts = farmMode ? '60s AJAX / 90s safety' : '15s AJAX / 20s safety';
        serverLog('===== STARTING TEST RUN =====');
        serverLog('Mode: ' + mode + ', Workers: ' + WORKER_COUNT + ', Tests: ' + urls.length);
        serverLog('AJAX timeouts: ' + ajaxTimeouts);
        runFirstBatch();
    });
</script>

<div id="workers">

</div>
<div>
    <div>
        <h1 id="title"></h1>
        <h2 id="branch"></h2>
    </div>
</div>
<iframe id="reportFrame" name="reportFrame"></iframe>
