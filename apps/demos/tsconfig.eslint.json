{
  "compilerOptions": {
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": false,
    "verbatimModuleSyntax": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["es2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "./Demos/**/React/**/*.ts",
    "./Demos/**/React/**/*.tsx",
    "./Demos/**/Vue/**/*.ts",
    "./Demos/**/Angular/**/*.ts",
    "./testing/**/*.ts"
  ]
}
