{
  "compilerOptions": {
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "strict": false,
    "verbatimModuleSyntax": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": ["es2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "Demos/Scheduler/**/React/**/*.tsx",
    "Demos/Scheduler/**/React/**/*.ts",
    "Demos/Diagram/**/React/**/*.tsx",
    "Demos/Diagram/**/React/**/*.ts",
    "Demos/FileManager/**/React/**/*.tsx",
    "Demos/FileManager/**/React/**/*.ts",
    "Demos/Gantt/**/React/**/*.tsx",
    "Demos/Gantt/**/React/**/*.ts",
    "Demos/VectorMap/**/React/**/*.tsx",
    "Demos/VectorMap/**/React/**/*.ts",
    "Demos/Charts/**/React/**/*.tsx",
    "Demos/Charts/**/React/**/*.ts",
    "Demos/Gauges/**/React/**/*.tsx",
    "Demos/Gauges/**/React/**/*.ts",
    "Demos/CardView/**/React/**/*.ts",
    "Demos/CardView/**/React/**/*.tsx",
    "Demos/FilterBuilder/**/React/**/*.ts",
    "Demos/FilterBuilder/**/React/**/*.tsx",
    "Demos/Sortable/**/React/**/*.ts",
    "Demos/Sortable/**/React/**/*.tsx",
    "Demos/TreeList/**/React/**/*.ts",
    "Demos/TreeList/**/React/**/*.tsx",
    "Demos/Accordion/**/React/**/*.tsx",
    "Demos/ActionSheet/**/React/**/*.tsx",
    "Demos/ContextMenu/**/React/**/*.tsx",
    "Demos/Menu/**/React/**/*.tsx",
    "Demos/MultiView/**/React/**/*.tsx",
    "Demos/Drawer/**/React/**/*.tsx",
    "Demos/TabPanel/**/React/**/*.tsx",
    "Demos/Tabs/**/React/**/*.tsx",
    "Demos/Toolbar/**/React/**/*.tsx",
    "Demos/Stepper/**/React/**/*.tsx",
    "Demos/Pagination/**/React/**/*.tsx",
    "Demos/List/**/React/**/*.tsx",
    "Demos/TreeView/**/React/**/*.tsx"
